{
  "name": "herbst-ui",
  "version": "0.0.2",
  "description": "CLI to add herbst UI components to your Angular project",
  "type": "module",
  "bin": {
    "herbst-ui": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "registry": "tsx src/scripts/build-registry.ts",
    "serve": "tsx src/scripts/serve-registry.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
